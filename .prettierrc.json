{
  "semi": true,
  "trailingComma": "all",
  "singleQuote": true,
  "printWidth": 80,
  "tabWidth": 2,
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": ["**/*.md"],
      "options": {
        "tabWidth": 2,
        "printWidth": 80,
        "proseWrap": "always"
      }
    }
  ]
}
